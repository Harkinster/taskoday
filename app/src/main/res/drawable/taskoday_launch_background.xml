<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#16051F" />
        </shape>
    </item>
    <item>
        <bitmap
            android:gravity="fill"
            android:src="@drawable/taskoday_world_background" />
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#6616051F"
                android:startColor="#00000000" />
        </shape>
    </item>
</layer-list>
